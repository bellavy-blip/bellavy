const fs = require('fs');
const path = require('path');

const DB_FILE = path.join(__dirname, 'data/db.json');

function load() {
  try {
    if (!fs.existsSync(DB_FILE)) return { users: [] };
    return JSON.parse(fs.readFileSync(DB_FILE, 'utf8'));
  } catch { return { users: [] }; }
}

function save(data) {
  fs.mkdirSync(path.dirname(DB_FILE), { recursive: true });
  fs.writeFileSync(DB_FILE, JSON.stringify(data, null, 2));
}

function getUser(id) {
  const u = load().users.find(u => (typeof u === 'string' ? u === id : u.id === id));
  if (!u) return null;
  return typeof u === 'string' ? { id: u, jid: u + '@s.whatsapp.net', name: 'Unknown', role: 'user' } : u;
}

function addUser(user) {
  const data = load();
  if (!data.users.find(u => u.id === user.id)) {
    data.users.push(user);
    save(data);
  }
  return user;
}

function setRole(id, role) {
  const data = load();
  const u = data.users.find(u => u.id === id);
  if (u) { u.role = role; save(data); }
}

function listUsers() {
  return load().users;
}


function getUserByJid(jid) {
  const id = jid.split('@')[0].split(':')[0];
  const u = load().users.find(u => (typeof u === 'string' ? u === id : (u.jid === jid || u.id === id)));
  if (!u) return null;
  return typeof u === 'string' ? { id: u, jid, name: 'Unknown', role: 'user' } : u;
}

