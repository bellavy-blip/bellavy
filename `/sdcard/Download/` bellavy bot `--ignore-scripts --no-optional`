const { handleMessage } = require('./bellavybot.js');

let pairingRequested = false;
let isConnecting = false;

async function connectToWhatsApp() {
  if (isConnecting) return;
  isConnecting = true;

  const sessionDir = './auth_session';
  if (!fs.existsSync(sessionDir)) fs.mkdirSync(sessionDir, { recursive: true });

  const { state, saveCreds } = await useMultiFileAuthState(sessionDir);
  const { version } = await fetchLatestWaWebVersion();

  const sock = makeWASocket({
    version,
    logger: pino({ level: 'silent' }),
    printQRInTerminal: false,
    browser: ['Windows', 'Chrome', '10'],
    wsOptions: {
      origin: 'https://web.whatsapp.com',
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120 Safari/537.36' }
    },
    auth: {
      creds: state.creds,
      keys: makeCacheableSignalKeyStore(state.keys, pino({ level: 'fatal' }).child({}))
    },
    markOnlineOnConnect: true,
    syncFullHistory: false,
    connectTimeoutMs: 60000,
    keepAliveIntervalMs: 10000,
    retryRequestDelayMs: 3000,
    getMessage: async () => ({ conversation: 'ok' })
  });

  sock.ev.on('creds.update', saveCreds);

  sock.ev.on('connection.update', async (update) => {
    const { connection, lastDisconnect } = update;
    if (connection === 'open') {
      console.log(chalk.green('\u2705 ' + global.botName + ' Connected!'));
      isConnecting = false; pairingRequested = false;
      return;
    }
    if (connection === 'connecting') {
      if (!state.creds.registered && !pairingRequested) {
        pairingRequested = true;
        try {
          await new Promise(r => setTimeout(r, 4000));
          const code = await sock.requestPairingCode(global.phoneNumber);
          console.log(chalk.cyan('\n📱 PAIRING CODE: ' + code + '\n'));
        } catch(e) {
          console.log(chalk.yellow('Pairing retry...'));
          pairingRequested = false;
        }
      }
      return;
    }
    if (connection === 'close') {
      const reason = new Boom(lastDisconnect?.error)?.output?.statusCode;
      console.log(chalk.yellow('\u26A0 Connection closed:'), reason);
      if (!state.creds.registered) {
        pairingRequested = false; isConnecting = false;
        setTimeout(() => connectToWhatsApp(), 4000);
        return;
      }
      if (reason !== DisconnectReason.loggedOut) {
        isConnecting = false;
        setTimeout(() => connectToWhatsApp(), 5000);
        return;
      }
      console.log(chalk.red('\u274C Logged out. Hapus folder auth_session lalu jalankan lagi.'));
      process.exit(0);
    }
  });

  sock.ev.on('messages.upsert', async ({ messages, type }) => {
    if (type !== 'notify') return;
    for (const m of messages) {
      if (!m.message || m.key.fromMe) continue;
      try { await handleMessage(sock, m); }
      catch(err) { console.log(chalk.red('Error: ' + err.message)); }
    }
  });

  return sock;
}

